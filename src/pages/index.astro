---
import Base from '../layouts/Base.astro';
---

<Base
  title="Waldo Vanderhaeghen"
  description="PM, builder, and occasional thinker. Writing about AI tooling, side projects, and product work."
>
  <section class="hero">
    <h1>Waldo Vanderhaeghen</h1>
    <p>PM · builder · curious about what AI actually changes.</p>
  </section>
</Base>

<style>
  .hero {
    max-width: var(--prose-width);
    margin: 4rem auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  p {
    color: var(--color-muted);
    font-size: 1.1rem;
  }
</style>
