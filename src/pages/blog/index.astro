---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const sorted = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const dateFormatter = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const byYear = sorted.reduce((acc, post) => {
  const y = post.data.pubDate.getFullYear();
  (acc[y] ??= []).push(post);
  return acc;
}, {} as Record<number, typeof sorted>);
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<Base
  title="Writing — Waldo Vanderhaeghen"
  description="Posts about AI tooling, automation, side projects, and product work."
>
  <div class="page">
    <h1>Writing</h1>
    {years.map(year => (
      <div class="year-group">
        <span class="year-label" aria-hidden="true">{year}</span>
        <ul class="post-list">
          {byYear[year].map(post => (
            <li class="post-item">
              <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-item__title">{post.data.title}</a>
              <p class="post-item__desc">{post.data.description}</p>
              <div class="post-item__meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFormatter.format(post.data.pubDate)}
                </time>
                {post.data.tags.length > 0 && (
                  <span class="post-item__tags">
                    {post.data.tags.map(t => `#${t}`).join(' ')}
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Base>

<style>
  .page {
    max-width: var(--prose-width);
    margin: 3rem auto;
    padding: 0 1.5rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  /* ── Year-grouped layout ─────────────────── */
  .year-group {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 0 var(--space-6);
    margin-bottom: var(--space-12);
  }

  .year-label {
    font-family: var(--font-serif);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-faint);
    letter-spacing: 0.06em;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    align-self: start;
    padding-top: 1.75rem;
  }

  .post-list {
    grid-column: 2;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--color-border);
    padding: 1.5rem 0;
  }
  .post-item:first-child { border-top: 1px solid var(--color-border); }

  .post-item__title {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: 0.4rem;
    line-height: 1.35;
    transition: color var(--duration-fast) var(--ease-out);
  }
  .post-item__title:hover { color: var(--color-accent); }

  .post-item__desc {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin: 0 0 0.6rem;
    line-height: 1.6;
  }

  .post-item__meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .post-item__tags { color: var(--color-accent); }

  @media (max-width: 480px) {
    .year-group {
      grid-template-columns: 2rem 1fr;
      gap: 0 var(--space-3);
    }
  }
</style>
