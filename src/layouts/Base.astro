---
import BaseHead from '../components/BaseHead.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-nav__home">Waldo Vanderhaeghen</a>
        <div class="site-nav__links">
          <a href="/blog">Writing</a>
          <a href="/about">About</a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        <a href="/impressum">Impressum</a>
        <span aria-hidden="true">·</span>
        <a href="/privacy">Privacy</a>
      </p>
    </footer>

    <div class="site-statusbar" aria-hidden="true">
      <span class="status-dot"></span>
      <span class="status-word"></span>
    </div>

    <CookieBanner />

    <script>
      // ── Claude Code status word cycler ───────────────────────────────
      const WORDS = [
        'jira-ing…',
        'roadmapping…',
        'strategizing…',
        'workshopping…',
        'aligning…',
        'incubating…',
        'deprioritizing…',
        'iterating…',
        'synergizing…',
        'triaging…',
        'visioning…',
        'parking-lot-ing…',
        'piloting…',
        'scoping…',
        'sprinting…',
        'waldoing…',
        'retro-ing…',
        'pivoting…',
        'socializing…',
        'de-risking…',
        'data-driving…',
        'dogfooding…',
        'spiking…',
        'deep-diving…',
        'stakeholdering…',
        'OKR-ing…',
        'grooming…',
        'circling-back…',
        'discovery-ing…',
        'prototyping…',
        'PRD-ing…',
        'baselining…',
        'benchmarking…',
        'ideating…',
        'leveraging…',
        'scrum-ing…',
        'KPI-ing…',
        'scaling…',
        'evangelizing…',
        'narrativing…',
        'sign-off-hunting…',
        'due-diligencing…',
        'documenting…',
      ];

      const el = document.querySelector('.status-word') as HTMLElement | null;
      if (el) {
        let wordIndex = 0;
        let charIndex = 0;
        let deleting = false;
        let pauseFrames = 0;

        function tick() {
          const word = WORDS[wordIndex];

          if (pauseFrames > 0) {
            pauseFrames--;
            setTimeout(tick, 80);
            return;
          }

          if (!deleting) {
            el.textContent = word.slice(0, charIndex + 1);
            charIndex++;
            if (charIndex === word.length) {
              deleting = true;
              pauseFrames = 22; // hold before deleting
            }
            setTimeout(tick, 75);
          } else {
            el.textContent = word.slice(0, charIndex - 1);
            charIndex--;
            if (charIndex === 0) {
              deleting = false;
              wordIndex = (wordIndex + 1) % WORDS.length;
              pauseFrames = 6;
            }
            setTimeout(tick, 40);
          }
        }

        // stagger start so it doesn't fire immediately on load
        setTimeout(tick, 1200);
      }

      // ── Sticky header: transparent → solid on scroll ─────────────────
      const siteHeader = document.querySelector('.site-header') as HTMLElement | null;
      if (siteHeader) {
        const onScroll = () => siteHeader.classList.toggle('scrolled', window.scrollY > 10);
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll(); // run once on load
      }

      // ── Spotlight: track mouse per card ──────────────────────────────
      document.querySelectorAll<HTMLElement>('.spotlight').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
          card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    /* Palette — warm European editorial */
    --color-bg:           #f9f5ee;
    --color-bg-raised:    #f4ede0;
    --color-text:         #2c2825;
    --color-muted:        #6b5f57;
    --color-faint:        #b8a89a;
    --color-accent:       #c4908a;
    --color-accent-hover: #a8736c;
    --color-accent-2:     #8fa898;
    --color-border:       #e8ddd4;
    --color-border-hover: #d4c4b8;
    --color-surface:      #ffffff;

    /* Typography */
    --font-serif: 'Lora', Georgia, serif;
    --font-sans:  'Inter', system-ui, sans-serif;
    --font-mono:  'JetBrains Mono', monospace;

    /* Type scale */
    --text-xs:   0.75rem;
    --text-sm:   0.875rem;
    --text-base: 1rem;
    --text-lg:   1.15rem;
    --text-xl:   1.35rem;
    --text-2xl:  1.75rem;
    --text-3xl:  2.25rem;

    /* Spacing — 4pt rhythm */
    --space-1:  0.25rem;
    --space-2:  0.5rem;
    --space-3:  0.75rem;
    --space-4:  1rem;
    --space-6:  1.5rem;
    --space-8:  2rem;
    --space-12: 3rem;
    --space-16: 4rem;

    /* Layout */
    --prose-width:   680px;
    --reading-width: 640px;

    /* Motion */
    --ease-out:       cubic-bezier(0.16, 1, 0.3, 1);
    --ease-in-out:    cubic-bezier(0.4, 0, 0.2, 1);
    --duration-fast:  150ms;
    --duration-base:  220ms;
    --duration-slow:  320ms;

    /* Elevation */
    --shadow-sm: 0 1px 3px rgba(44, 40, 37, 0.06), 0 1px 2px rgba(44, 40, 37, 0.04);
    --shadow-md: 0 4px 12px rgba(44, 40, 37, 0.08), 0 2px 4px rgba(44, 40, 37, 0.04);
    --shadow-lg: 0 8px 24px rgba(44, 40, 37, 0.10), 0 4px 8px rgba(44, 40, 37, 0.04);

    /* Border radius */
    --radius-sm: 0.25rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
  }

  html { font-size: 18px; }

  body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    line-height: 1.7;
    margin: 0;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  a { color: var(--color-accent); text-decoration-thickness: 1px; text-underline-offset: 3px; transition: color var(--duration-fast) var(--ease-out); }
  a:hover { color: var(--color-accent-hover); }

  /* Entrance animation */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-in {
    animation: fadeUp var(--duration-slow) var(--ease-out) both;
  }
  .animate-in[data-delay="1"] { animation-delay: 40ms; }
  .animate-in[data-delay="2"] { animation-delay: 80ms; }
  .animate-in[data-delay="3"] { animation-delay: 120ms; }
  .animate-in[data-delay="4"] { animation-delay: 160ms; }
  .animate-in[data-delay="5"] { animation-delay: 200ms; }

  @media (prefers-reduced-motion: reduce) {
    .animate-in { animation: none; opacity: 1; transform: none; }
  }

  /* Site header */
  .site-header {
    border-bottom: 1px solid transparent;
    padding: 1rem 1.5rem;
    background: transparent;
    position: sticky;
    top: 0;
    z-index: 100;
    transition:
      background 200ms var(--ease-out),
      border-color 200ms var(--ease-out);
  }

  .site-header.scrolled {
    background: var(--color-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom-color: var(--color-border);
  }

  .site-nav {
    max-width: var(--prose-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  /* Nav links — white over cover photo, normal color when scrolled */
  .site-nav__home {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color var(--duration-fast) var(--ease-out);
    text-shadow: 0 1px 4px rgba(44, 40, 37, 0.4);
  }
  .site-nav__home:hover { color: rgba(255, 255, 255, 1); }

  .site-header.scrolled .site-nav__home {
    color: var(--color-text);
    text-shadow: none;
  }
  .site-header.scrolled .site-nav__home:hover { color: var(--color-accent); }

  .site-nav__links {
    display: flex;
    gap: 1.5rem;
    font-size: var(--text-sm);
  }

  .site-nav__links a {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    position: relative;
    transition: color var(--duration-fast) var(--ease-out);
    text-shadow: 0 1px 4px rgba(44, 40, 37, 0.4);
  }

  .site-nav__links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.8);
    transition: width var(--duration-base) var(--ease-out);
  }

  .site-nav__links a:hover::after { width: 100%; }
  .site-nav__links a:hover { color: rgba(255, 255, 255, 1); }

  .site-header.scrolled .site-nav__links a {
    color: var(--color-muted);
    text-shadow: none;
  }
  .site-header.scrolled .site-nav__links a::after { background: var(--color-accent); }
  .site-header.scrolled .site-nav__links a:hover { color: var(--color-text); }

  /* Site footer — normal flow, only visible when scrolled to bottom */
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-muted);
  }
  .site-footer a { color: var(--color-muted); }
  .site-footer a:hover { color: var(--color-accent); }
  .site-footer p { display: flex; gap: 0.75rem; justify-content: center; margin: 0; }

  /* Status bar — always visible, sticky at bottom */
  .site-statusbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-faint);
    letter-spacing: 0.04em;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent-2);
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.75); }
  }

  .status-word {
    display: inline-block;
    min-width: 12ch;
    text-align: left;
  }

  /* Spotlight card effect */
  .spotlight {
    position: relative;
    overflow: hidden;
  }

  .spotlight::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(196, 144, 138, 0.08),
      transparent 60%
    );
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
    pointer-events: none;
    z-index: 0;
    border-radius: inherit;
  }

  .spotlight:hover::before { opacity: 1; }
</style>
